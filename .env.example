# .env.example — Copy this to .env and fill in your actual values
# NEVER commit the .env file to GitHub

# OpenAI API Key (for the Planning Agent cloud model)
OPENAI_API_KEY=your_openai_api_key_here

# Alternatively, if using Anthropic Claude as cloud model
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Ollama base URL (default — change only if you're running Ollama on a different port)
OLLAMA_BASE_URL=http://localhost:11434

# ChromaDB persistence directory
CHROMA_PERSIST_DIR=./data/chroma_db

# Embedding model name
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2